@model List<SchoolManagement.Web.Models.Course>

@{
    ViewData["Title"] = "รายวิชา";
}

<h2>รายวิชา</h2>

@if (TempData["Success"] is string success)
{
    <script>
        alert(@Html.Raw(Json.Serialize(success)))
    </script>
}

@if (TempData["Error"] is string error)
{
    <script>
        alert(@Html.Raw(Json.Serialize(error)))
    </script>
}

<a href="/Course/Create" class="btn-add" style="padding: 8px 12px; background-color: #28a745; color: white; text-decoration: none; border-radius: 4px;">เพิ่มวิชา</a>

<table border="1" style="border-collapse: collapse; width: 100%; margin-top: 15px;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px;">ชื่อวิชา</th>
            <th style="padding: 8px;">หน่วยกิต</th>
            <th style="padding: 8px;">อาจารย์ผู้สอน</th>
            <th style="padding: 8px;">จัดการ</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td style="padding: 8px;">@course.CourseName</td>
                <td style="padding: 8px; text-align: center;">@course.Credit</td>

                @* <td style="padding: 8px; text-align: center;">
                    <a asp-action="List_Teachers" asp-route-id="@course.CourseId" 
                       style="padding: 4px 10px; background-color: #17a2b8; color: white; text-decoration: none; border-radius: 4px; font-size: 14px;">
                        ดูรายชื่ออาจารย์
                    </a>
                </td> *@

                <td style="padding: 8px;">
                  @if (string.IsNullOrWhiteSpace(course.TeacherNames))
                  {
                      <span style="color: gray;">ยังไม่มีอาจารย์</span>
                  }
                  else
                  {
                      <span>@course.TeacherNames</span>
                  }

                  <br />

                  <a asp-action="List_Teachers" asp-route-id="@course.CourseId"
                     style="display: inline-block; margin-top: 6px; padding: 4px 10px; background-color: #17a2b8; color: white; text-decoration: none; border-radius: 4px; font-size: 14px;">
                    ดูรายชื่ออาจารย์
                  </a>

                </td>

                <td style="padding: 8px; text-align: center;">
                    <a asp-action="Details" asp-route-id="@course.CourseId">รายละเอียด</a> |
                    <a asp-action="Edit" asp-route-id="@course.CourseId">แก้ไข</a> |
                    <form asp-action="Delete" method="post" style="display: inline;"
                          onsubmit="return confirm('ต้องการลบวิชานี้ใช่หรือไม่?');">
                        <input type="hidden" name="id" value="@course.CourseId" />
                        <button type="submit" style="background: none; border: none; color: blue; text-decoration: underline; cursor: pointer; padding: 0;">ลบ</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>