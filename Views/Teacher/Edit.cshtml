@model SchoolManagement.Web.Models.Teacher

@{
    ViewData["Title"] = "แก้ไขอาจารย์";
}

<h2>แก้ไขอาจารย์</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="TeacherId" />
    <div asp-validation-summary="All"></div>
    <div>
        <label>ชื่ออาจารย์</label>
        <input type="text" name="TeacherName" value="@Model.TeacherName" />
    </div>
    <div>
        <label>สาขา</label>
        <select name="MajorId">
            @foreach (var major in ViewBag.Majors)
            {
                <option value="@major.MajorId" selected="@(major.MajorId == Model.MajorId)">@major.MajorName</option>
            }
        </select>
    </div>
    <button type="submit">บันทึก</button>
    <a href="/Teacher">ยกเลิก</a>
</form>